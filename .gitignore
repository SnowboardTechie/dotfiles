.DS_Store
!AGENTS.md
configstore
dot-gitconfig.github
dot-gitconfig.local
dot-gitconfig.snowboardtechie

dot-config/exercism/*

# Opencode - track config and lock files, ignore local artifacts
dot-config/opencode/*
!dot-config/opencode/
!dot-config/opencode/package.json
!dot-config/opencode/bun.lock
!dot-config/opencode/opencode.json
!dot-config/opencode/oh-my-openagent.json
!dot-config/opencode/AGENTS.md
!dot-config/opencode/agents/
dot-tmux/plugins/
dot-config/alacritty/alacritty.toml
dot-config/fj-dash/
dot-config/gh/
dot-config/containers/
dot-config/sol/
dot-config/grafana/
dot-config/openchamber/
dot-config/gcloud/
dot-config/gws/
dot-config/uv/

# Claude Code - track personal config and authored content, ignore local artifacts
dot-claude/*
!dot-claude/
!dot-claude/CLAUDE.md
!dot-claude/settings.json
!dot-claude/agents/
!dot-claude/scripts/
!dot-claude/scheduled-tasks/
!dot-claude/hud/
# Runtime log from the SessionStart hook script
dot-claude/scripts/symlink-worktree-agents-md.log

# Secrets - machine-specific, never committed
.secrets/
dot-config/watch/*

# GPG - only track gpg-agent.conf, ignore everything else
dot-gnupg/*
!dot-gnupg/gpg-agent.conf

# Stale backups from opencode config edits
*.backup*
