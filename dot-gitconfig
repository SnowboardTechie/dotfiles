[user]
	name = Bryan Thompson

[include]
	path = ~/.gitconfig.snowboardtechie
	path = ~/.gitconfig.local

[commit]
	gpgsign = true

[core]
	excludesfile = ~/.config/git/ignore
	fileMode = false
	hooksPath = ~/.git-hooks
	editor = nvim

[credential]
	helper = cache --timeout=3600

[push]
	autoSetupRemote = true
[branch]
	autosetuprebase = always
	rebase = true

[init]
	defaultBranch = main
[credential "https://git.snowboardtechie.com"]
	helper =
	helper = !tea login helper
