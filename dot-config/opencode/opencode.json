{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      }
    },
    "openrouter": {
      "models": {
        "anthropic/claude-opus-4.7": {},
        "anthropic/claude-sonnet-4.6": {},
        "anthropic/claude-haiku-4.5": {},
        "openai/gpt-5.5": {},
        "openai/gpt-5.4-mini": {},
        "openai/gpt-5.3-codex": {},
        "google/gemini-3.1-pro-preview": {},
        "google/gemini-3-flash-preview": {},
        "x-ai/grok-code-fast-1": {}
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Open WebUI (ai.thompson.codes)",
      "options": {
        "baseURL": "https://ai.thompson.codes/ollama/v1",
        "apiKey": "{file:~/.secrets/opencode-api-key}"
      },
      "models": {
        "qwen3.6:35b-a3b-coding-nvfp4": {
          "name": "Qwen3.6 Coder",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "gemma4:26b-mlx": {
          "name": "Gemma 4 26B",
          "limit": {
            "context": 262144,
            "output": 16384
          }
        },
        "gemma4:12b-nvfp4": {
          "name": "Gemma 4 12B Fast",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "instructions": ["README.md", "AGENTS.md"],
  "permission": {
    "bash": {
      "*": "allow"
    },
    "edit": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "task": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "external_directory": "ask",
    "doom_loop": "ask"
  },
  "model": "ollama/qwen3.6:35b-a3b-coding-nvfp4",
  "plugin": [],
  "mcp": {}
}
