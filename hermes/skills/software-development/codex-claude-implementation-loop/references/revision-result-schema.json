{
  "title": "Claude revision worker result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "files_changed",
    "tests",
    "findings_addressed",
    "unresolved_findings",
    "blockers",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "status", "summary"],
        "properties": {
          "command": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "summary": {"type": "string"}
        }
      }
    },
    "findings_addressed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "unresolved_findings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
